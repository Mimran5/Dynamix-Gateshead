{
  "version": 2,
  "buildCommand": "cd project && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "project/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "builds": [
    {
      "src": "project/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ]
} 